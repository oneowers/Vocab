generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id                      String                     @id @default(uuid())
  email                   String                     @unique
  name                    String?
  avatarUrl               String?
  role                    Role                       @default(USER)
  learningGoal            LearningGoal?
  dailyWordTarget         Int?
  onboardingStep          OnboardingStep             @default(QUESTIONS)
  onboardingCompletedAt   DateTime?
  levelTestEstimatedLevel CefrLevel?
  levelTestConfidence     Json?
  levelTestCompletedAt    DateTime?
  levelTestMistakes       Int?
  levelTestCorrect        Int?
  cefrLevel               CefrLevel                  @default(A1)
  reviewLives             Int                        @default(3)
  createdAt               DateTime                   @default(now())
  lastActiveAt            DateTime?
  streak                  Int                        @default(0)
  lastReviewDate          String?
  streakFreezes           Int                        @default(0)
  lastStreakRecoveryDate  String?
  firstPracticeDate       String?
  cards                   Card[]
  catalogClaims           UserCatalogWord[]
  reviewLogs              ReviewLog[]
  grammarSkills           UserGrammarSkill[]
  grammarFindings         GrammarFinding[]
  practiceSession         PracticeSessionProgress?
  writingChallenges       PracticeWritingChallenge[]
  proUntil                DateTime?
  promoUsages             PromoCodeUsage[]
}

enum Role {
  USER
  PRO
  ADMIN
}

enum LearningGoal {
  IELTS
  WORK
  DAILY_ENGLISH
  TRAVEL
  OTHER
}

enum OnboardingStep {
  QUESTIONS
  LEVEL_TEST
  FIRST_WORDS
  COMPLETED
}

enum CefrLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum UserCatalogWordStatus {
  ACTIVE
  KNOWN
}

enum CatalogEnrichmentStatus {
  pending
  completed
  failed
}

enum CatalogReviewStatus {
  draft
  approved
}

enum GrammarSeverity {
  low
  medium
  high
}

enum GrammarFindingSourceType {
  writing_challenge
}

model Card {
  id                      String       @id @default(uuid())
  userId                  String
  user                    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  catalogWordId           String?
  catalogWord             WordCatalog? @relation(fields: [catalogWordId], references: [id], onDelete: SetNull)
  original                String?
  translation             String?
  translationAlternatives String[]     @default([])
  direction               String
  example                 String?
  phonetic                String?
  dateAdded               DateTime     @default(now())
  nextReviewDate          String
  lastReviewResult        String       @default("unknown")
  reviewCount             Int          @default(0)
  correctCount            Int          @default(0)
  wrongCount              Int          @default(0)

  @@index([userId, catalogWordId])
  @@index([userId, nextReviewDate, dateAdded(sort: Desc)], map: "idx_card_user_due_added")
  @@index([userId, lastReviewResult, nextReviewDate], map: "idx_card_user_status_due")
}

model ReviewLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId    String
  result    String
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)], map: "idx_reviewlog_user_created_desc")
  @@index([createdAt(sort: Desc), userId], map: "idx_reviewlog_created_user")
}

model AppAnalytics {
  id                   String @id @default(uuid())
  date                 String @unique
  totalSessions        Int    @default(0)
  totalReviews         Int    @default(0)
  newUsers             Int    @default(0)
  newCards             Int    @default(0)
  activeUsersD1        Int    @default(0)
  activeUsersD7        Int    @default(0)
  activeUsersD30       Int    @default(0)
  wrongByA1            Int    @default(0)
  wrongByA2            Int    @default(0)
  wrongByB1            Int    @default(0)
  wrongByB2            Int    @default(0)
  wrongByC1            Int    @default(0)
  wrongByC2              Int    @default(0)
  catalogClaimsToday     Int    @default(0)
  catalogVsCustomRatio   Float  @default(0)
  onboardingStarted      Int    @default(0)
  onboardingCompleted    Int    @default(0)
  levelTestStarted       Int    @default(0)
  levelTestCompleted     Int    @default(0)
  firstWordsSelected     Int    @default(0)
  firstPracticeStarted   Int    @default(0)
  firstPracticeCompleted Int    @default(0)
  aiChallengeStarted     Int    @default(0)
  aiChallengeCompleted   Int    @default(0)
  firstPracticeD1Return  Int    @default(0)
}

model PracticeSessionProgress {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardIds         String[]
  completedStages String[] @default([])
  activeStage     String
  selectedStatus  String   @default("All")
  flow            String   @default("linked")
  state           Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, updatedAt])
}

model PracticeWritingChallenge {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardIds         String[]
  targetWords     Json
  userText        String
  score           Int
  levelFeedback   String
  usedWords       Json
  grammarMistakes Json
  grammarFindings Json     @default("[]")
  grammarScoreAppliedAt DateTime?
  whatWasGood     String
  improvedText    String
  nextTask        String
  createdAt       DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

model GrammarTopic {
  id          String             @id @default(uuid())
  key         String             @unique
  titleEn     String
  titleRu     String
  category    String
  cefrLevel   CefrLevel
  description String
  examples    Json               @default("[]")
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  userSkills  UserGrammarSkill[]
  findings    GrammarFinding[]

  @@index([isActive, cefrLevel, category])
}

model UserGrammarSkill {
  id                    String       @id @default(uuid())
  userId                String
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicId               String
  topic                 GrammarTopic @relation(fields: [topicId], references: [id], onDelete: Restrict)
  score                 Int          @default(0)
  evidenceCount         Int          @default(0)
  positiveEvidenceCount Int          @default(0)
  negativeEvidenceCount Int          @default(0)
  lastDetectedAt        DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@unique([userId, topicId])
  @@index([userId, score])
  @@index([topicId])
}

model GrammarFinding {
  id             String                   @id @default(uuid())
  userId         String
  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicId        String
  topic          GrammarTopic             @relation(fields: [topicId], references: [id], onDelete: Restrict)
  sourceType     GrammarFindingSourceType
  sourceId       String?
  originalText   String
  correctedText  String
  explanationRu  String
  severity       GrammarSeverity
  confidence     Float
  isCorrect      Boolean                  @default(false)
  scoreDelta     Int
  createdAt      DateTime                 @default(now())

  @@unique([sourceType, sourceId, topicId])
  @@index([userId])
  @@index([topicId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([sourceType, sourceId])
}

model WordCatalog {
  id                      String                  @id @default(uuid())
  word                    String                  @unique
  translation             String
  translationAlternatives String[]                @default([])
  cefrLevel               CefrLevel
  partOfSpeech            String
  topic                   String
  example                 String
  phonetic                String
  priority                Int                     @default(0)
  isPublished             Boolean                 @default(false)
  source                  String?
  sourceRef               String?
  enrichmentStatus        CatalogEnrichmentStatus @default(completed)
  reviewStatus            CatalogReviewStatus     @default(approved)
  lastEnrichedAt          DateTime?
  enrichmentError         String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  search_vector           Unsupported("tsvector")?
  cards                   Card[]
  claims                  UserCatalogWord[]

  @@index([isPublished, cefrLevel, priority(sort: Desc), createdAt], map: "idx_wordcatalog_pub_level_priority_created")
  @@index([reviewStatus, enrichmentStatus], map: "idx_wordcatalog_review_enrichment")
  @@index([source, sourceRef])
}

model UserCatalogWord {
  id            String                @id @default(uuid())
  userId        String
  wordCatalogId String
  status        UserCatalogWordStatus @default(ACTIVE)
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordCatalog   WordCatalog           @relation(fields: [wordCatalogId], references: [id], onDelete: Cascade)
  createdAt     DateTime              @default(now())

  @@unique([userId, wordCatalogId])
  @@index([userId, status, createdAt])
}

model AppSettings {
  id                  String   @id @default("app")
  dailyNewCardsLimit  Int      @default(5)
  reviewLives         Int      @default(3)
  cefrProfilerEnabled Boolean  @default(true)
  translationProvider String   @default("auto")
  translationPriority String[] @default(["catalog", "deepl", "langeek"])
  updatedAt           DateTime @updatedAt
}

model PromoCode {
  id              String            @id @default(uuid())
  code            String            @unique
  description     String?
  maxUses         Int?
  currentUses     Int               @default(0)
  expiresAt       DateTime?
  isActive        Boolean           @default(true)
  proDurationDays Int               @default(30)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  usages          PromoCodeUsage[]
}

model PromoCodeUsage {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, promoCodeId])
}
